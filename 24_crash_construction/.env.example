# 돌관공사비 노무비 출력일보 경로 설정
# 이 파일을 복사해 .env 로 저장하고 실제 경로를 입력하세요.
# .env 는 git에서 제외됩니다 (.gitignore: **/.env)

# 템플릿 Excel 파일 전체 경로 (회사명 포함 실제 파일명으로 지정)
CRASH_TEMPLATE_PATH=C:\...\sample_돌관공사비 산출근거.xlsx

# 소스 파일 폴더 경로
CRASH_SOURCE_DIR=C:\...\source

# 출력 파일 경로
CRASH_OUTPUT_PATH=C:\...\돌관공사비_산출근거_자동생성_v8.xlsx
