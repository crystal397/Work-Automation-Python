            {
              "$ref": "#/$defs/Sourced_str_"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "제2023-1-146-202301-NN호"
        },
        "period_start": {
          "$ref": "#/$defs/Sourced_date_"
        },
        "period_end": {
          "$ref": "#/$defs/Sourced_date_"
        },
        "duration_days": {
          "$ref": "#/$defs/Sourced_int_"
        },
        "duration_diff_days": {
          "$ref": "#/$defs/Sourced_int_",
