        "period_start": {
          "$ref": "#/$defs/Sourced_date_"
        },
        "period_end": {
          "$ref": "#/$defs/Sourced_date_"
        },
        "days": {
          "$ref": "#/$defs/Sourced_int_"
        },
        "excluded_periods": {
          "items": {
            "$ref": "#/$defs/ExcludedPeriod"
          },
          "title": "Excluded Periods",
          "type": "array"
        }
      },
      "required": [
        "period_start",
        "period_end",
        "days"
      ],
      "title": "CalculationTarget",
      "type": "object"
    },
    "ClientType": {
      "enum": [
        "국가",
        "지방",
        "민간"
      ],
